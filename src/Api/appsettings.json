{
  "AllowedHosts": "*",
  "ConnectionStrings": {}, // do not commit non-empty connection strings to force an error if one isn't correctly set in an environment (rather than accidentally using an incorrect value)
  "Databases": {
    "Application": {
      "SqlServer": {
        "Api": {
          "ConnectionBehavior": {
            "ConnectionStringName": "SqlServer",
            "ReplacePassword": true,
            "ReplaceUserId": true,
            "UserId": "api"
          }
        }
      }
    }
  },
  "DbProvider": "SqlServer",
  "HttpLogging": {
    "Enabled": true
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
