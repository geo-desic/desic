{
  "Databases": {
    "Desic": {
      "Migrations": {
        "Enabled": true
      },
      "Seeding": {
        "Enabled": true
      }
    }
  },
  "DbProvider": "SqlServer",
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}