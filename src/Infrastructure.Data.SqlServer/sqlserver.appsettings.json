{
  "Databases": {
    "Application": {
      "SqlServer": {
        "Contained": true,
        "Name": "Desic",
        "Roles": [
          {
            "Name": "rl_api",
            "Grants": [
              {
                "Schema": "app",
                "Permissions": [ "SELECT", "INSERT", "UPDATE", "DELETE" ]
              },
              {
                "Schema": "ref",
                "Permissions": [ "SELECT" ]
              }
            ]
          }
        ],
        "Schemas": [
          {
            "Name": "app"
          },
          {
            "Name": "ref"
          }
        ],
        "StopIfExists": true,
        "Users": [
          {
            "Name": "api",
            "PasswordConfigKey": "Databases:Application:ApiUserPassword",
            "LoginName": "api",
            "DefaultSchema": "app",
            "Roles": [ "rl_api" ]
          },
          {
            "Name": "migrations",
            "PasswordConfigKey": "Databases:Application:MigrationsUserPassword",
            "LoginName": "migrations",
            "Roles": [ "db_owner" ]
          }
        ]
      }
    }
  }
}