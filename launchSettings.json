{
  "profiles": {
    "All": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "serviceActions": {
        "api": "StartDebugging",
        "web": "StartWithoutDebugging",
        "dbupdater": "StartWithoutDebugging",
        "sqlserver": "StartWithoutDebugging"
      }
    },
    "Sql Server": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "serviceActions": {
        "api": "DoNotStart",
        "web": "DoNotStart",
        "dbupdater": "DoNotStart",
        "sqlserver": "StartWithoutDebugging"
      }
    },
    "Api Only": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "composeLaunchAction": "LaunchBrowser",
      "composeLaunchServiceName": "api",
      "composeLaunchUrl": "{Scheme}://localhost:{ServicePort}/openapi/v1.json",
      "serviceActions": {
        "api": "StartDebugging",
        "web": "DoNotStart",
        "dbupdater": "DoNotStart",
        "sqlserver": "DoNotStart"
      }
    },
    "Api & Web": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "serviceActions": {
        "api": "StartDebugging",
        "web": "StartWithoutDebugging",
        "dbupdater": "DoNotStart",
        "sqlserver": "DoNotStart"
      }
    },
    "Db Updater": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "serviceActions": {
        "api": "DoNotStart",
        "dbupdater": "StartWithoutDebugging",
        "web": "DoNotStart",
        "sqlserver": "StartWithoutDebugging"
      }
    }
  }
}