{
  // note most other settings will be inherited from appsettings.json in the Desic.Api project, so only include/override what is actually needed for integration testing here
  // database are automatically created and deleted during integration tests and connection strings automatically generated for them, so connection strings are not needed here
  "Databases": {
    "Desic": {
      "Migrations": {
        "Enabled": true
      },
      "Seeding": {
        "Enabled": true,
        "Test": {
          "Enabled": true,
          "Users": {
            "Count": 5
          }
        }
      }
    }
  },
  "DbProvider": "SqlServer",
  "DbProviders": {
    "SqlServer": {
      "ContainerImage": "mcr.microsoft.com/mssql/server:2025-latest",
      "UseContainer": true
    }
  },
  "HttpLogging": {
    "Enabled": false
  }
}