{
  // note most other settings will be inherited from appsettings.json in the Api project, so only include/override what is actually needed for integration testing here
  "ConnectionStrings": {
    // only used when DbProvider == SqlServer and DbProviders:UseContainer == false
    // this should be a connection string for a local sql server (e.g. localdb or sql server express) master database connection
    // each test database will be created on this server with a unique name and cleaned up at the end of the test run
    // this server should have access to the executing user's temporary directory as that is where the test database files (*.bak, *.ldf, *.mdf) will be stored
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Integrated Security=true;"
  },
  "Databases": {
    "Application": {
      "Migrations": {
        "Enabled": true
      },
      "Seeding": {
        "Enabled": true,
        "Test": {
          "Enabled": true,
          "Users": {
            "Count": 5
          }
        }
      }
    }
  },
  "DbProvider": "SqlServer",
  "DbProviders": {
    "SqlServer": {
      "ContainerImage": "mcr.microsoft.com/mssql/server:2022-latest",
      "UseContainer": false
    }
  },
  "HttpLogging": {
    "Enabled": false
  }
}