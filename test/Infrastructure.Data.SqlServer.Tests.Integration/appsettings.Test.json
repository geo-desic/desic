{
  "ConnectionStrings": {
    // only used when DbProviders:UseContainer == false
    // this should be a connection string for a local sql server master database (e.g. localdb / sql server express)
    // each test database will be created on this server with a unique name and cleaned up at the end of the test run
    // this server should have access to the executing user's temporary directory as that is where some test files (*.bak) might be stored
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Integrated Security=true;"
  },
  "Databases": {
    "Application": {
      "Migrations": {
        "Enabled": true
      },
      "Seeding": {
        "Enabled": true,
        "Test": {
          "Enabled": true,
          "Users": {
            "Count": 10
          }
        }
      },
      "SqlServer": {
        "Initialization": {
          "ConnectionBehavior": {
            "ConnectionStringName": "SqlServer",
            "RemoveInitialCatalog": true,
            "ReplacePassword": false, // not applicable when Integrated Security=true
            "ReplaceUserId": false // not applicable when Integrated Security=true
          }
        }
      }
    }
  },
  "DbProviders": {
    "SqlServer": {
      "ContainerImage": "mcr.microsoft.com/mssql/server:2022-latest",
      "UseContainer": true
    }
  }
}