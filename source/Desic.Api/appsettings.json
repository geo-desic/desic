{
  "AllowedHosts": "*",
  "ConnectionStrings": {}, // do not commit non-empty connection strings to force an error if one isn't correctly set in an environment (rather than accidentally using an incorrect value)
  "Databases": {
    "Desic": {
      "EnableSensitiveDataLogging": false
    }
  },
  "HttpLogging": {
    "Enabled": true
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
