{
  "ConnectionStrings": {
    // overrided by environment variables in docker-compose.yml at solution level when running using vs docker-compose startup project
    "Sqlite": "Data Source=./desic.db;",
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=Desic;Integrated Security=true;"
  },
  "DesicContext": {
    "EnableSensitiveDataLogging": true
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
