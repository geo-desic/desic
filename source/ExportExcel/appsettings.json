{
  "ConnectionStrings": {
    "PrimaryDb": "Server=(localdb)\\MSSQLLocalDB;Database=Desic;Integrated Security=true;"
  },
  "ExportFileNamePrefix": "entities",
  "Queries": [
    {
      "Name": "Tags",
      "Value": "SELECT * FROM [app].[Tags] WHERE [Name] = @SystemTagName;"
    },
    {
      "Name": "Users",
      "Value": "SELECT U.* FROM [app].[Users] AS U INNER JOIN [app].[Tags] AS T ON (T.[Id] = U.[CreatedById]) WHERE T.[Name] = @SystemTagName;"
    }
  ],
  "Parameters": [
    {
      "Name": "@SystemTagName",
      "Value": "System"
    }
  ]
}